# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://beamup:beamup_secret@localhost:27019/beamup_db?authSource=admin

# PostgreSQL (Prisma)
DATABASE_URL=postgresql://beamup:beamup_secret@localhost:5432/beamup_db?schema=public

# Redis
REDIS_URL=redis://:beamup_secret@localhost:6379

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=beamup-api
KAFKA_GROUP_ID=beamup-consumers

# OpenAI
OPENAI_API_KEY=sk-...

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# JWT (if needed)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
