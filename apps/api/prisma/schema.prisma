// Prisma schema — PostgreSQL
// Owns: relational/transactional data (orders, audit logs)
// Auth users live in MongoDB only — userId here is the MongoDB _id string
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Order {
  id           String      @id @default(cuid())
  userId       String?     // MongoDB user _id (no FK — cross-DB reference)
  sku          String
  quantity     Int
  status       OrderStatus @default(PENDING)
  warehouseId  String
  priority     String      @default("normal")
  notes        String?
  triggeredBy  String      @default("manual") // "agent" | "manual"
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([sku])
  @@index([warehouseId])
  @@map("orders")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  // MongoDB user _id
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}
